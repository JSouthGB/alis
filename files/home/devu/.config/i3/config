## App shortcuts

# Browser
bindsym $mod+w exec librewolf

# File Manager
bindsym $mod+n exec dolphin

# PDF Reader Zathura 
#bindsym $mod+Shift+o exec zathura

# Screenshot : FlameShot
#bindsym Print exec flameshot full --path ~/Pictures/screenshots
bindsym $mod+F12 exec flameshot gui

# start a terminal
bindsym $mod+Return exec alacritty

# ibus
#bindsym $mod+Shift+b exec ibus-setup

# Network Manager Applet
bindsym Mod1+Shift+n exec --no-startup-id nm-applet

# Rofi
#bindsym $mod+d exec --no-startup-id rofi -show drun -disable-history -show-icons
bindsym $mod+d exec $HOME/.config/polybar/blocks/scripts/launcher.sh &
#bindsym Mod1+d exec --no-startup-id rofi -show run -disable-history
bindsym Mod1+d exec --no-startup-id rofi -show run
bindsym Mod1+w exec rofi -show window -show-icons
bindsym Mod1+m exec rofi -modi emoji -show emoji

# kill focused window
bindsym $mod+Shift+q kill

# exit-menu
#bindsym $mod+Shift+e exec $HOME/.config/i3/scripts/power.sh
bindsym $mod+Shift+e exec $HOME/.config/polybar/blocks/scripts/powermenu.sh &

# Lock the system
