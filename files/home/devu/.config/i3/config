bindsym $mod+Shift+x exec i3lock -i $HOME/.config/background/illustration-city-anime-painting-wallpaper-13f4d2d68139f5ef0b47c1ea2a545254.png -c 000000

# reload the configuration file
bindsym $mod+Shift+c reload

# restart i3 inplace (preserves your layout/session, can be used to update i3)
bindsym $mod+Shift+r restart

# Background
#exec --no-startup-id feh --bg-scale $HOME/.config/background/firewatch-dark-minimal-5k-58.jpg
exec --no-startup-id feh --bg-fill $HOME/.config/background/illustration-city-anime-painting-wallpaper-13f4d2d68139f5ef0b47c1ea2a545254.png

